<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_fund_allocation_tree" model="ir.ui.view">
        <name>fund.allocation.tree</name>
        <model>fund.allocation</model>
        <arch type="xml">
            <list string="Fund Allocations">
                <field name="name"/>
                <field name="amount"/>
                <field name="spent_amount"/>
                <field name="remaining_amount"/>
            </list>
        </arch>
    </record>

    <record id="view_fund_allocation_form" model="ir.ui.view">
        <name>fund.allocation.form</name>
        <model>fund.allocation</model>
        <arch type="xml">
            <form string="Fund Allocation">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="amount"/>
                        </group>
                        <group>
                            <field name="spent_amount"/>
                            <field name="remaining_amount" readonly="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </arch>
    </record>

    <record id="action_fund_allocation" model="ir.actions.act_window">
        <name>Fund Allocations</name>
        <res_model>fund.allocation</res_model>
        <view_mode>list,form</view_mode>
    </record>

    <menuitem id="menu_fund_root" name="Fund Management" web_icon="base,images/modules.png" sequence="10"/>
    <menuitem id="menu_fund_allocation" name="Allocations" parent="menu_fund_root" action="action_fund_allocation" sequence="10"/>
</odoo>